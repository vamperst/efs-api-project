# Copie para .env (gitignored) e preencha com SEUS valores.
# Usado por scripts shell/Python locais (deploy, build, report).

# AWS - use o profile SSO que VOCE configurou em ~/.aws/config
# Para logar (antes de rodar qualquer `make` / `terraform`):
#     aws sso login --profile <SEU_PROFILE_AQUI>
# Session expira apos ~8h - basta repetir o comando para renovar.
AWS_REGION=us-east-1
AWS_PROFILE=<SEU_PROFILE_AQUI>

# Projeto (bate com var.project nas stacks Terraform)
PROJECT=efs-api-lab
ENV=dev

# Overrides opcionais
# API_IMAGE_TAG=v1
# TARGET_DATA_SIZE_GB=100
