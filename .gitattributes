# Normaliza line endings e marca binarios
* text=auto eol=lf

# Shell scripts SEMPRE LF (quebram em Windows se CRLF)
*.sh     text eol=lf
*.bash   text eol=lf

# Python / config
*.py     text eol=lf diff=python
*.tf     text eol=lf
*.tfvars text eol=lf
*.hcl    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf

# Batch files Windows precisam CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binarios
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar    binary
*.gz     binary

# Drawio e JSON grandes: util para diff
*.drawio text eol=lf diff=xml linguist-language=XML
