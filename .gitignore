# =============================================================================
# Claude Code / local IDE state — nunca deve ir pro repo
# =============================================================================
.claude/
.claude-code/
CLAUDE.local.md

# =============================================================================
# Segredos / credenciais — NUNCA commitar
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials
credentials.json
.aws/
.aws-credentials
.secrets/
secrets.yml
secrets.yaml
secrets.json
*.kubeconfig

# =============================================================================
# Terraform (estado, caches, backend preenchido, lock, plan outputs)
# =============================================================================
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# backend.hcl preenchido por stack contem nome de bucket + tabela especificos
# da conta. Regerar com write-backend-hcl.sh. O exemplo continua versionado.
**/backend.hcl
!**/backend.hcl.example

# tfvars podem conter dados sensiveis; versione apenas .tfvars.example
*.tfvars
*.auto.tfvars
!*.tfvars.example

# plan outputs (costumam vazar dados)
*.tfplan
*.tfplan.json
tfplan
plan.out

# State LOCAL da stack 00-backend (bootstrap) — ela usa local backend,
# entao o arquivo existe. Guarde esse state em local seguro, NAO no repo.
efs-api-project/terraform/00-backend/terraform.tfstate
efs-api-project/terraform/00-backend/terraform.tfstate.backup

# Terraform crash reports
crash.log
crash.*.log

